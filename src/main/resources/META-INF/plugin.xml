<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.github.peco2282.mcdatapack</id>
    <name>MC-Datapack</name>
    <vendor>peco2282</vendor>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Minecraft Function" language="McFunction"
                  implementationClass="com.github.peco2282.mcdatapack.language.psi.McFunctionFileType"
                  extensions="mcfunction"/>
        <lang.parserDefinition language="McFunction"
                               implementationClass="com.github.peco2282.mcdatapack.language.psi.McFunctionParserDefinition"/>
        <lang.syntaxHighlighterFactory language="McFunction"
                                       implementationClass="com.github.peco2282.mcdatapack.language.highlighting.McFunctionSyntaxHighlighterFactory"/>
        <annotator language="McFunction"
                   implementationClass="com.github.peco2282.mcdatapack.language.highlighting.McFunctionAnnotator"/>
        <colorSettingsPage
                implementation="com.github.peco2282.mcdatapack.language.highlighting.McFunctionColorSettingsPage"/>
        <completion.contributor language="McFunction"
                                implementationClass="com.github.peco2282.mcdatapack.language.completion.McFunctionCompletionContributor"/>
        <lang.commenter language="McFunction"
                        implementationClass="com.github.peco2282.mcdatapack.language.formatting.McFunctionCommenter"/>
        <lang.braceMatcher language="McFunction"
                           implementationClass="com.github.peco2282.mcdatapack.language.formatting.McFunctionPairedBraceMatcher"/>
        <typedHandler implementation="com.github.peco2282.mcdatapack.language.formatting.McFunctionQuoteHandler"/>
        <lang.foldingBuilder language="McFunction"
                             implementationClass="com.github.peco2282.mcdatapack.language.formatting.McFunctionFoldingBuilder"/>
        <lang.psiStructureViewFactory language="McFunction"
                                      implementationClass="com.github.peco2282.mcdatapack.language.structure.McFunctionStructureViewFactory"/>
        <psi.referenceContributor language="McFunction"
                                  implementation="com.github.peco2282.mcdatapack.language.reference.McFunctionReferenceContributor"/>
        <lang.findUsagesProvider language="McFunction"
                                 implementationClass="com.github.peco2282.mcdatapack.language.reference.McFunctionFindUsagesProvider"/>
        <lang.documentationProvider language="McFunction"
                                    implementationClass="com.github.peco2282.mcdatapack.language.documentation.McFunctionDocumentationProvider"/>
        <lang.formatter language="McFunction"
                        implementationClass="com.github.peco2282.mcdatapack.language.formatting.McFunctionFormattingModelBuilder"/>
        <langCodeStyleSettingsProvider
                implementation="com.github.peco2282.mcdatapack.language.formatting.McFunctionLanguageCodeStyleSettingsProvider"/>

        <toolWindow factoryClass="com.github.peco2282.mcdatapack.toolWindow.MyToolWindowFactory" id="MC-Datapack" anchor="right"/>
        <postStartupActivity implementation="com.github.peco2282.mcdatapack.startup.MyProjectActivity"/>
        <notificationGroup id="MC-Datapack" displayType="BALLOON" isLogByDefault="true"/>
        <liveTemplateContext contextId="McFunction" implementation="com.github.peco2282.mcdatapack.language.template.McFunctionTemplateContextType"/>
        <codeInsight.inlayProvider language="McFunction" implementationClass="com.github.peco2282.mcdatapack.language.inlay.McFunctionInlayHintsProvider"/>
        <spellchecker.support language="McFunction"
                              implementationClass="com.github.peco2282.mcdatapack.language.highlighting.McFunctionSpellcheckingStrategy"/>
        <directoryProjectGenerator implementation="com.github.peco2282.mcdatapack.project.McDatapackProjectGenerator"/>
        <moduleBuilder builderClass="com.github.peco2282.mcdatapack.project.McDatapackModuleBuilder"/>
    </extensions>
</idea-plugin>
